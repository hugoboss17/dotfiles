#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(dirname "$SCRIPT_DIR")"

sudo apt-get update

echo "Installing apt packages.."
while IFS= read -r pkg || [ -n "$pkg" ]; do
    pkg="${pkg%%#*}"
    pkg="$(printf '%s' "$pkg" | tr -d '\r' | xargs)"
    [ -z "$pkg" ] && continue
    sudo apt-get install -y "$pkg"
done < "$DOTFILES_DIR/packages/apt-packages"

for script in "$SCRIPT_DIR/install.d/"*; do
    [ -f "$script" ] && bash "$script"
done

if [ -f "$DOTFILES_DIR/packages/Vscode" ]; then
    while IFS= read -r ext || [ -n "$ext" ]; do
        ext="${ext%%#*}"
        ext="$(printf '%s' "$ext" | tr -d '\r' | xargs)"
        [ -z "$ext" ] && continue
        code --install-extension "$ext" --force || true
    done < "$DOTFILES_DIR/packages/Vscode"
fi

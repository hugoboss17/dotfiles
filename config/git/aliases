alias glog="git log --graph --decorate"
alias glogs="git log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"
alias glogd="git log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)' --all"
alias gcl="git clone"
alias ga="git add"
alias g="git"
alias gs="git status"
alias gst="git status"
alias gpush="git push"
alias gpull="git pull"
alias gf="git fetch --all"
alias gm="git checkout master"
alias gmp="git checkout master && git pull"
alias gdev="git checkout develop"
alias gdevp="git checkout develop && git pull"
alias gcf="git checkout feature/$1"
alias gcfp="git checkout feature/$1 && git pull"
alias gch="git checkout hotfix/$1"
alias gchp="git checkout hotfix/$1 && git pull"
alias gff="gdevp && git merge feature/$1 && git push && gmp && git merge feature/$1 && git push"
alias gfh="gdevp && git merge hotfix/$1 && git push && gmp && git merge hotfix/$1 && git push"
alias gmerge="git mergetool --tool=Kdiff3"
alias gcommit="git commit -m '$1'"
alias gmakef="gdevp && git checkout -b feature/$1"
alias gmakeh="gmp && git checkout -b hotfix/$1"
alias gsave="git stash"
alias gload="git stash pop"